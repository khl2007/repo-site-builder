var _userHistoryListTpl_En='<tr class="u-text-left"><td>{{splabel}}</td><td>{{atime}}</td></tr>',_userHistoryListTpl_Ar='<tr class="u-text-right"><td>{{splabel}}</td><td>{{atime}}</td></tr>';String.prototype.endsWith||(String.prototype.endsWith=function(a,c){var b=this.toString();if("number"!==typeof c||!isFinite(c)||Math.floor(c)!==c||c>b.length)c=b.length;c-=a.length;b=b.indexOf(a,c);return-1!==b&&b===c});
