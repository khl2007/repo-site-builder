hideFavNav=function(){$("#favouritesNavMain").addClass("hide")};showAlertsNavMain=function(){$("#alertsNavMain").removeClass("hide")};hideAlertsNavMain=function(){$("#alertsNavMain").addClass("hide")};showCurrentUserNavMain=function(){$("#currentUserNavMain").removeClass("hide")};hideCurrentUserNavMain=function(){$("#currentUserNavMain").addClass("hide")};function setCurrentAuthUser(a){try{document.getElementById("currentAuthUser").innerHTML=a}catch(c){}}
function initIdpLogin(){try{window.location="/idpinit/login"}catch(a){}}var userActReq={};
function fetchUserRecentAct(a,c,b,d,e){userActReq={serviceURL:a,lang:c,actpl:b,inData:d,pgpl:e};$("#spinner").show();$.ajax({url:a,dataType:"text",type:"post",data:d,timeout:3E4,success:function(a){$("#spinner").hide();if(""==a)return!1;var d;try{if((d=parseJson(a))&&d.code)console.error("User Activity Error:"),showNoDataError();else if(updateRecentSps(d.data,c,b),0>currentPage||0==numberOfPages)currentPage=d.page,numberOfPages=d.numberOfPages,"en"==c?initiatePagesBar():initiatePagesBarAr()}catch(e){console.error("Error parsing User Activity response :",
e),showNoDataError()}},error:function(a,b,c){$("#spinner").hide();console.error("Error User Activity:",a);showNoDataError()}})}showNoDataError=function(){$("#empty-list-warning").removeClass("hide")};hideNoDataError=function(){$("#empty-list-warning").addClass("hide")};var currentPage=-1,numberOfPages=0;
function initiatePagesBar(){var a=document.createElement("span");a.className="u-justify-center   u-mh-small ";a.id="#page-count";a.style="display:flex; align-items:center;";a.textContent=currentPage+" / "+numberOfPages;document.getElementById("#pages-list").prepend(createIcon("feather icon-chevron-left",goToPreviousPage));document.getElementById("#pages-list").prepend(createIcon("feather icon-chevrons-left",goToFirstPage));document.getElementById("#pages-list").appendChild(a);document.getElementById("#pages-list").append(createIcon("feather icon-chevron-right",
goToNextPage));document.getElementById("#pages-list").append(createIcon("feather icon-chevrons-right",goToLastPage))}
function initiatePagesBarAr(){var a=document.createElement("span");a.className="u-justify-center   u-mh-small ";a.id="#page-count";a.style="display:flex; align-items:center;";a.textContent=currentPage+" / "+numberOfPages;document.getElementById("#pages-list").prepend(createIcon("feather icon-chevron-right",goToPreviousPage));document.getElementById("#pages-list").prepend(createIcon("feather icon-chevrons-right",goToFirstPage));document.getElementById("#pages-list").appendChild(a);document.getElementById("#pages-list").append(createIcon("feather icon-chevron-left",
goToNextPage));document.getElementById("#pages-list").append(createIcon("feather icon-chevrons-left",goToLastPage))}function updateCount(){document.getElementById("#page-count").textContent=" "+currentPage+" / "+numberOfPages+" "}function createIcon(a,c){var b=document.createElement("div");b.className="c-pagination__link is-active";b.style="cursor: pointer;";b.onclick=c;var d=document.createElement("i");d.className=a;b.appendChild(d);return b}
function goToNextPage(){currentPage<numberOfPages&&(currentPage+=1,updateCount(),fetchUserRecentAct(userActReq.serviceURL,userActReq.lang,userActReq.actpl,"req=rapm&p="+currentPage))}function goToPreviousPage(){0<currentPage-1&&(--currentPage,updateCount(),fetchUserRecentAct(userActReq.serviceURL,userActReq.lang,userActReq.actpl,"req=rapm&p="+currentPage))}
function goToFirstPage(){currentPage=1;updateCount();fetchUserRecentAct(userActReq.serviceURL,userActReq.lang,userActReq.actpl,"req=rapm&p="+currentPage)}function goToLastPage(){currentPage=numberOfPages;updateCount();fetchUserRecentAct(userActReq.serviceURL,userActReq.lang,userActReq.actpl,"req=rapm&p="+currentPage)};
