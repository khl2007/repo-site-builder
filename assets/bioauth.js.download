var FingerprintCapture_APPLET=null;function InitializeFingerprintApplet(){if(null==FingerprintCapture_APPLET||void 0==FingerprintCapture_APPLET.isLoaded)FingerprintCapture_APPLET=document.getElementById("FingerprintCapture_Applet");null==FingerprintCapture_APPLET&&HandleError(E_APPLET_NOT_INITIALIZED,"Applet not intialized")}function HandleError(a,b){document.getElementById("ERROR_LABEL").innerHTML=b}
function SubmitBIOFPInitForm(a){document.getElementById("NAT_ID");13==(a||window.event).keyCode&&document.getElementById("BIOFPForm").submit();return!0}function SubmitBIOFPMatchForm(){var a=document.getElementById("BIO_FINGERIMAGE").value;if(void 0==a||null==a||0==a.length)return StartCapture(),!1;authenticate(a)}
function SetFingersId(a,b){document.getElementById("FirstFingerId").value=a;document.getElementById("SecondFingerId").value=b;document.getElementById("FirstFingerImage").setAttribute("src","/images/"+a+".jpg");document.getElementById("SecondFingerImage").setAttribute("src","/images/"+b+".jpg")}var Working=!1;
function StartCapture(){$("#errors").hide();document.getElementById("BIO_FINGERIMAGE").value="";document.getElementById("ERROR_LABEL").innerHTML="";InitializeFingerprintApplet();document.getElementById("ReadImageBtn").disabled=!0;document.getElementById("StopImageBtn").disabled=!1;Working?alert("Capturing Image In Progress ..."):(document.getElementById("BIO_FINGERIMAGE").value="",FingerprintCapture_APPLET.captureFingerprint(1,!0,30),Working=!0)}
function StopCapture(){null!=FingerprintCapture_APPLET&&(FingerprintCapture_APPLET.stopCaptureFingerprint(),Working=!1,document.getElementById("ReadImageBtn").disabled=!1,document.getElementById("StopImageBtn").disabled=!0,document.getElementById("BIO_FINGERIMAGE").value="")}
function FingerprintCapturedEvent(){null!=FingerprintCapture_APPLET&&(image=FingerprintCapture_APPLET.getCapturedFingerprint(),document.getElementById("BIO_FINGERIMAGE").value=image,Working=!1,document.getElementById("ReadImageBtn").disabled=!1,document.getElementById("StopImageBtn").disabled=!0,SubmitBIOFPMatchForm())}function FingerprintCaptureError(a){alert(getErrorMessage(a));document.getElementById("BIO_FINGERIMAGE").value="";Working=!1;HandleError(a,getErrorMessage(a))}
function FingerprintEnableJSCalls(){document.getElementById("ReadImageBtn").disabled=!1;StartCapture()}function deployFingerprintApplet(){deployJava.runApplet({id:"FingerprintCapture_Applet",code:"org.nic.bio.capture.FingerprintCaptureApplet.class",archive:"/nicidp/NIC_DigitalPersonaSigned.jar",width:"180",height:"180",style:"border:1px solid gray"},{scriptable:!0,separate_jvm:!0,type:"application/x-java-applet;version=1.3"},"1.6")};
