IDCARD_SIGNING_APPLET_ID="idcard_offline_signing_applet";function ResetPIN(){document.getElementsByName("Action").value="PINRESET";document.forms.IDCardForm.submit()}function SetErrorMessage(a){document.getElementById("ErrorMessage").innerHTML="Error "+a+" : "+getErrorMessage(a)}function SetChallenge(a){document.getElementById("hxChallenge").value=a}
function SignChallenge(){HXChallenge=document.getElementById("hxChallenge").value;Password=document.getElementById("txtPIN").value;document.getElementById("txtPIN").value="";IDCard_SignChallenge(HXChallenge,Password)}
function RawSignChallenge(){HXChallenge=document.getElementById("hxChallenge").value;Password=document.getElementById("txtPIN").value;4>Password.length?(HandleError("-1",getErrorMessage("-1")),$("#spinner").hide()):(document.getElementById("txtPIN").value="",IdCardSignChallenge(HXChallenge,Password,function(a){handleSignedChallenge(a.signedChallenge,a.certificate)},HandleError))}
function HandleAuthSuccess(a,b){document.getElementById("IDC_RS").value=a;document.getElementById("IDC_SC").value=b;authenticate()}function HandleError(a,b){document.getElementById("ERROR_LABEL").innerHTML=b+"("+a+").";$("#spinner").hide()}function TestIDP_IDCard_Authenticate(){PIN=document.getElementById("txtPIN").value;HXChallenge=document.getElementById("hxChallenge").value;IDP_IDCard_Authenticate(PIN,HXChallenge)}
function TestUPAuthenticateApplet(){ServerUrl=document.getElementById("txtAuthServiceURL").value;Username=document.getElementById("USERNAME").value;Password=document.getElementById("PASSWORD").value;IssuerUrl=document.getElementById("txtIssuerURL").value;UP_Authenticate(ServerUrl,Username,Password,IssuerUrl)}
function TestSRPAuthenticateApplet(){ServerUrl=document.getElementById("txtAuthServiceURL").value;Username=document.getElementById("USERNAME").value;Password=document.getElementById("PASSWORD").value;IssuerUrl=document.getElementById("txtIssuerURL").value;SRP_Authenticate(ServerUrl,Username,Password,IssuerUrl)}
function TestUPPAuthenticateApplet(){ServerUrl=document.getElementById("txtAuthServiceURL").value;Username=document.getElementById("USERNAME").value;Password=document.getElementById("PASSWORD").value;IssuerUrl=document.getElementById("txtIssuerURL").value;UPP_Authenticate(ServerUrl,Username,Password,IssuerUrl)}
function TestUPAuthenticateAjax(){ServerUrl=document.getElementById("txtAuthServiceURL").value;Username=document.getElementById("USERNAME").value;Password=document.getElementById("PASSWORD").value;IssuerUrl=document.getElementById("txtIssuerURL").value;document.getElementById("PASSWORD").value="";UP_AuthenticateAjax(ServerUrl,Username,Password,IssuerUrl)}
function TestUPPAuthenticateAjax(){ServerUrl=document.getElementById("txtAuthServiceURL").value;Username=document.getElementById("USERNAME").value;Password=document.getElementById("PASSWORD").value;IssuerUrl=document.getElementById("txtIssuerURL").value;document.getElementById("PASSWORD").value="";UPP_AuthenticateAjax(ServerUrl,Username,Password,IssuerUrl)}
function TestAuthenticate(){var a=document.getElementById("vv").value;"Username/Password with Applet"==a&&TestUPAuthenticateApplet();"Username/Password with Ajax"==a&&TestUPAuthenticateAjax();"Username/Password And One Time Password with Applet"==a&&TestUPPAuthenticateApplet();"Username/Password And One Time Password with Ajax"==a&&TestUPPAuthenticateAjax();"Secure Remote Password"==a&&TestUPPAuthenticateAjax()}function ReadMCDID(){IDCard_ReadMCDID();$("#spinner").hide()}
function ReadCSNAndNatId(){IdCardReadCSNAndNatId(function(a){handleCSNAndNationalIDResponse(a.csnAndNationalId)},HandleError);$("#spinner").hide()}
function IdCard_SignDataAndExportCertAndCSN(a,b){-1<navigator.userAgent.toLowerCase().indexOf("chrome")&&0>navigator.userAgent.toLowerCase().indexOf("edge")?SignDataAndExportCertAndCSN(a,b):-1<navigator.userAgent.toLowerCase().indexOf("firefox")?SignDataAndExportCertAndCSNFirefox(a,b):document.documentMode&&SignDataAndExportCertAndCSNIE(a,b);$("#spinner").hide()}function ReadCSN(){IDCard_ReadCSN()}function ReadNationalId(){IDCard_ReadNationalId()}
function HandleMCDIDReadSuccess(a){document.getElementById("MCDID").value=a;authenticate()}function HandleCSNAndNationalIDReadSuccess(a){a=a.split(",");document.getElementById("CSN").value=a[0];document.getElementById("NAT_ID").value=a[1];authenticate()}function HandleCSNReadSuccess(a){document.getElementById("CSN").value=a;document.forms.IDCardForm.submit()}function HandleNationalIdReadSuccess(a){document.getElementById("NAT_ID").value=a}function IdCardNoUpdateOptionLogin(){authenticate()}
function PisPinResetOptionNext(){IDCard_ReadNationalId();document.getElementById("IDC_PR_MODE").value=document.getElementById("AuthenticationMethodOption").value;document.forms.PinResetInitForm.submit()}function handleCSNAndNationalIDResponse(a){a=a.split(",");document.getElementById("CSN").value=a[0];document.getElementById("NAT_ID").value=a[1];authenticate()}function handleSignDataAndExportCertAndCSN(a){handleSignDataAndExportCertAndCSNImpl(a)}
function handleSignedChallenge(a,b){document.getElementById("IDC_RS").value=a;document.getElementById("IDC_SC").value=b;authenticate()};
