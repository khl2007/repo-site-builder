var authMethodsTpl ="<form> <input name=\"selectedSecuence\" id=\"selectedSecuence\" type=\"hidden\" /> <input name=\"startover\" id=\"startover\" type=\"hidden\" /> </form> <div class=\"row u-justify-center \"> {{#options}} <button class=\"collapsible\" onclick=\"handleClick({{value}}, 'pl{{value}}', this.getAttribute('class'));\">{{name}}</button> <div class=\"content\" id=\"pl{{value}}\"> <form style=\"padding: 25px;text-align: center;\"> <h3 id=\"placeholder1\">الرجاء الانتظار حتى يتم جلب البيانات</h3> </form> </div> {{#selected}} <script> var option; if ({{ selected }} === true) { option = {{ value }}; } else { option = 1; } </script> {{/selected}} {{/options}} </div> <div class=\"clr\"> </div> <script> let flag = false; function handleClick(value, placeholder, atr) { let e = window.event; e.preventDefault(); if (atr === 'collapsible active') { flag = true; } else { startOverAuth(value, placeholder); flag = false; } }   let seloption = option || 1; window.addEventListener('load', function () { slelectAuth(seloption, \"pl\" + seloption); }); var coll = document.getElementsByClassName(\"collapsible\"); var i; coll[seloption - 1].classList.toggle(\"active\"); var content = coll[seloption - 1].nextElementSibling; content.style.maxHeight = \"1200px\"; content.style.width = \"100%\"; content.classList.toggle(\"active\"); for (i = 0; i < coll.length; i++) { coll[i].addEventListener(\"click\", function () { if (flag) { return false; } document.querySelectorAll(\".collapsible\").forEach(function (el, index) { if (el.classList.value === 'collapsible active') { el.classList.toggle(\"active\"); el.nextElementSibling.style.maxHeight = null; el.nextElementSibling.innerHTML = ''; el.nextElementSibling.classList.toggle(\"active\"); } });  this.classList.toggle(\"active\"); var content = this.nextElementSibling; content.classList.toggle(\"active\"); content.style.maxHeight = \"1200px\"; content.style.width = \"100%\";  }); } </script> ";